# Copy to .env.local and fill with your keys

# Finnhub API Configuration
# Get your API key from https://finnhub.io
VITE_FINNHUB_API_KEY=your_finnhub_api_key_here
VITE_FINNHUB_BASE_URL=https://finnhub.io/api/v1
VITE_FINNHUB_WS_URL=wss://ws.finnhub.io

# Indian Stock Market API Configuration
# Get your API key from https://api.indianapi.com or alternative provider
VITE_INDIAN_API_KEY=your_indian_api_key_here
VITE_INDIAN_API_BASE_URL=https://api.indianapi.in

# Alpha Vantage API Configuration
# Get your API key from https://www.alphavantage.co
VITE_ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here
VITE_ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query

# Optional: Cache duration in milliseconds (default values shown)
# VITE_CACHE_DURATION_QUOTE=300000
# VITE_CACHE_DURATION_CHART=600000
# VITE_CACHE_DURATION_INDIAN_STOCKS=600000
# VITE_CACHE_DURATION_CUSTOM=300000
